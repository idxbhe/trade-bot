# KuCoin API Credentials (V3/HF Trading)
# Dapatkan di https://www.kucoin.com/account/api
KUCOIN_API_KEY=kucoin_api_key
KUCOIN_API_SECRET=kucoin_secret
KUCOIN_API_PASSPHRASE=kucoin_passphrase

# Konfigurasi Simulasi (Test Mode)
# Saldo awal virtual Anda dalam USDT untuk Paper Trading lokal (Murni Logika Bot, bukan API Testnet)
TEST_INITIAL_BALANCE=100

# Konfigurasi Anti-Blokir ISP (Opsional)
# Jika KuCoin diblokir oleh ISP/TrustPositif, isi URL proxy di bawah ini.
# Contoh HTTP: http://192.168.1.100:8080
# Contoh SOCKS5: socks5://127.0.0.1:1080 (Butuh: pip install aiohttp-socks)
# Kosongkan saja jika koneksi internet Anda normal atau jika Anda sudah pakai VPN/WARP.
BOT_PROXY_URL=
